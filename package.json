{
  "name": "sauce-demo-automation",
  "version": "1.0.0",
  "description": "Automated testing suite for Sauce Demo using Playwright and Cucumber",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js",
    "test:headed": "cross-env HEADLESS=false cucumber-js",
    "test:slowmo": "cross-env HEADLESS=false SLOW_MO=100 cucumber-js",
    "test:report": "cucumber-js --format html:reports/cucumber-report.html --format json:reports/cucumber-report.json",
    "clean": "rm -rf reports/* screenshots/*"
  },
  "keywords": [
    "playwright",
    "cucumber",
    "automation",
    "testing"
  ],
  "author": "Enrique Castro",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^10.3.1",
    "@playwright/test": "^1.42.1",
    "@types/node": "^20.19.37",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
